{
  "name": "choops-extractor",
  "version": "0.5.4",
  "description": "A command-line utility to extract textures and other files from College Hoops 2K8 (PS3)",
  "bin": {
    "choops-extractor": "./index.js"
  },
  "main": "index.js",
  "scripts": {
    "pack": "pkg -t node18-win-x64 -o dist/choops-extractor.exe --compress GZip ."
  },
  "author": "", 
  "license": "MIT",
  "dependencies": {
    "commander": "^9.1.0",
    "make-dir": "^3.1.0",
    "winston": "^3.7.2"
  },
  "pkg": {
    "assets": [
      "./2k-tools/lib/gtf2dds.exe",
      "./2k-tools/lib/dds2gtf.exe"
    ]
  },
  "devDependencies": {
    "chai": "^4.3.6",
    "mocha": "^10.0.0"
  }
}
