{
  "name": "choops-extractor",
  "version": "0.5.9",
  "description": "A command-line utility and research suite for College Hoops 2K8 (PS3) textures, archives, CDF/IFF pairs, and rosters",
  "bin": {
    "choops-extractor": "./index.js",
    "choops-roster": "./roster.js"
  },
  "main": "index.js",
  "scripts": {
    "pack": "pkg -t node18-win-x64 -o dist/choops-extractor.exe --compress GZip . && node scripts/copy-native-tools.js",
    "roster": "node roster.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^9.1.0",
    "env-paths": "^2.2.1",
    "long": "^5.2.3",
    "make-dir": "^3.1.0",
    "stream-chunker": "^1.2.8",
    "stream-parser": "^0.3.1",
    "uuid": "^8.3.2",
    "winston": "^3.7.2"
  },
  "pkg": {
    "assets": [
      "./2k-tools/lib/gtf2dds.exe",
      "./2k-tools/lib/dds2gtf.exe"
    ]
  },
  "devDependencies": {
    "chai": "^4.3.6",
    "mocha": "^10.0.0",
    "pkg": "^5.8.1"
  }
}
